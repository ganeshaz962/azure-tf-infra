# Terraform providers and plugins (can be very large binaries)
**/.terraform/

# Terraform state files (may contain sensitive data)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Terraform crash logs
crash.log
crash.*.log

# Terraform plan output files
*.tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
